# Worker deploy config — copy to .env on the worker machine
# cp .env.worker-deploy .env
#
# If worker runs ON the same machine as the server, use 127.0.0.1
# If worker runs on a different machine, use the server's public IP
QUEUE_HOST=127.0.0.1
QUEUE_PORT=9999
QUEUE_POLL=2
QUEUE_DBS=main=/var/lib/myapp/main.db,logs=/var/lib/myapp/logs.db
USER_DB_DIR=/var/lib/myapp/users
