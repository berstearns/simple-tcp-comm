# Copy to .env and fill in your values
QUEUE_HOST=YOUR_DO_IP
QUEUE_PORT=9999
QUEUE_POLL=2

# Worker only
# WORKER_NAME=homelab          # defaults to hostname
# QUEUE_DBS=main=/path/to/main.db,logs=/path/to/logs.db

# Supervisor (auto-update)
# DEPLOY_BRANCH=main           # git branch to track
# UPDATE_INTERVAL=300           # seconds between update checks
# GRACE_TIMEOUT=60              # seconds to wait for worker before SIGKILL
